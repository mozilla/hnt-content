# Local development config for `pnpm --filter crawl-agent dev`.
# Copy to .env and adjust as needed. .env is gitignored. In deployed
# environments these come from the Helm chart, not from a file.

# HTTP port for the /healthz liveness probe.
# PORT=8080

# Tick loop interval and the staleness threshold that fails /healthz.
# TICK_INTERVAL_MS=60000
# STALE_TICK_THRESHOLD_MINUTES=10
