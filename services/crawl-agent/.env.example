# Local development config for `pnpm --filter crawl-agent dev`.
# Copy to .env and fill in the blanks. .env is gitignored; never
# commit real values. In deployed environments these come from the
# Helm chart and GSM, not from a file.

# GCP project that owns the Pub/Sub topics.
PROJECT_ID=moz-fx-hnt-nonprod

# Deploy environment. The agent derives Pub/Sub topic names from it
# (dev -> dev-crawl-article-discovery, dev-crawl-article) and tags
# Sentry with it.
ENVIRONMENT=dev

# Path to the publisher list JSON loaded at startup. See
# publishers.example.json for the format.
PUBLISHER_LIST_PATH=publishers.json

# Redis (Memorystore) for enqueue-dedup state.
REDIS_HOST=
REDIS_PORT=6379

# How often the agent re-enqueues a live article (minutes).
# LIVE_ARTICLE_INTERVAL_MINUTES=20

# Override the derived topic names directly, e.g. for emulator topics.
# CRAWL_ARTICLE_DISCOVERY_TOPIC=
# CRAWL_ARTICLE_TOPIC=

# Point the Pub/Sub SDK at a local emulator instead of real GCP.
# Leave unset to use real Pub/Sub via your gcloud credentials.
# PUBSUB_EMULATOR_HOST=localhost:8085
