# Local development config for `pnpm --filter crawl-agent dev`.
# Copy to .env and fill in the blanks. .env is gitignored; never
# commit real values. In deployed environments these come from the
# Helm chart and GSM, not from a file.

# GCP project that owns the Pub/Sub topics.
PROJECT_ID=moz-fx-hnt-nonprod

# Deploy environment. The agent derives Pub/Sub topic names from it
# (dev -> dev-crawl-article-discovery, dev-crawl-article) and tags
# Sentry with it.
ENVIRONMENT=dev

# Path to the publisher list JSON loaded at startup. pages always come
# from this file; see publishers.example.json for the format. Generate
# the full list from the curated source with scripts/generate-publishers.py;
# the generated publishers.json is gitignored.
PUBLISHER_LIST_PATH=publishers.json

# Corpus Admin API source for live (curated) articles. Set the JWK to
# fetch the currently scheduled section items per surface from the
# Corpus API; leave it unset to use the file's live_articles instead.
# The endpoint/issuer/audience have app defaults (nonprod admin-api
# outside prod). The JWK is a secret (RSA private key as JWK JSON).
# CORPUS_API_JWK_JSON=
# CORPUS_API_ENDPOINT=
# CORPUS_API_ISSUER=
# CORPUS_API_AUDIENCE=
# Comma-separated New Tab surfaces to read live articles from.
# CORPUS_SCHEDULED_SURFACE_GUIDS=NEW_TAB_EN_US
# How often to re-read the live-article list from the Corpus API (minutes).
# CORPUS_REFRESH_MINUTES=15

# Redis (Memorystore) for enqueue-dedup state.
REDIS_HOST=
REDIS_PORT=6379

# Operational metrics (StatsD UDP to the MozCloud OTEL gateway). The
# default host is the in-cluster gateway; set empty to disable locally
# so unresolved-DNS errors are not logged.
STATSD_HOST=
# STATSD_PORT=8125

# How often the agent re-enqueues a live article (minutes).
# LIVE_ARTICLE_INTERVAL_MINUTES=20

# Override the derived topic names directly, e.g. for emulator topics.
# CRAWL_ARTICLE_DISCOVERY_TOPIC=
# CRAWL_ARTICLE_TOPIC=

# Point the Pub/Sub SDK at a local emulator instead of real GCP.
# Leave unset to use real Pub/Sub via your gcloud credentials.
# PUBSUB_EMULATOR_HOST=localhost:8085
