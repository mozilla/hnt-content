{
  "name": "crawl-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/main.js",
    "dev": "tsx --env-file-if-exists=.env src/main.ts",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "crawl-common": "workspace:*",
    "express": "^5.1.0",
    "metrics": "workspace:*",
    "pubsub": "workspace:*",
    "redis-state": "workspace:*",
    "sentry": "workspace:*"
  },
  "devDependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "@testcontainers/gcloud": "^11.14.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^10.0.0",
    "supertest": "^7.0.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
