# Local development config for `pnpm --filter crawl-worker dev:article`.
# Copy to .env and fill in the blanks. .env is gitignored; never
# commit real keys. In deployed environments these come from the
# Helm chart and GSM, not from a file.

# WORKER_ROLE is set by the dev:article / dev:discovery scripts, not here.

# GCP project that owns the Pub/Sub topics and subscriptions.
PROJECT_ID=moz-fx-hnt-nonprod

# Your personal Zyte API key for local runs.
ZYTE_API_KEY=

# Deploy environment. The worker derives Pub/Sub names from it
# (dev -> dev-crawl-article, dev-articles) and tags Sentry with it.
ENVIRONMENT=dev

# Override the derived names directly, e.g. for emulator topics.
# CRAWL_ARTICLE_SUBSCRIPTION=
# ARTICLES_TOPIC=

# Point the Pub/Sub SDK at a local emulator instead of real GCP.
# Leave unset to use real Pub/Sub via your gcloud credentials.
# PUBSUB_EMULATOR_HOST=localhost:8085

# Corpus API JWK (RSA private key) to enable live-article sync. The
# endpoint, issuer, and audience have app defaults; leave the JWK
# unset to skip Corpus updates locally.
# CORPUS_API_JWK_JSON=
